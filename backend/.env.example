# ClientPilotAI Backend Environment Variables
# Copy this file to .env and fill in the required keys

# Server Configuration
PORT=3001

# Frontend URL (set this on Railway so CORS works for your Vercel deployment)
FRONTEND_URL=https://your-app.vercel.app

# Supabase API Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# CRITICAL: Service role key bypasses Row Level Security (RLS). NEVER expose this key to the frontend!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase JWT Secret (obtained from Settings -> API -> JWT Settings)
# Used to verify incoming Bearer access tokens from the frontend
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Gemini API Configuration (used for AI lead scoring, outreach, and proposal generation)
# Get your key at: https://aistudio.google.com/app/apikey
# Key must start with "AIzaSy..." — any other format will be rejected at startup
GEMINI_API_KEY=AIzaSy-your-gemini-api-key-here
