# ClientPilotAI Backend Environment Variables
# Copy this file to .env and fill in the required keys

# Server Configuration
PORT=3001

# Supabase API Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# CRITICAL: Service role key bypasses Row Level Security (RLS). NEVER expose this key to the frontend!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase JWT Secret (obtained from Settings -> API -> JWT Settings)
# Used to verify incoming Bearer access tokens from the frontend
SUPABASE_JWT_SECRET=your-jwt-secret-here

# OpenAI API Configuration (used for AI lead scoring and outreach generation)
OPENAI_API_KEY=sk-proj-your-openai-api-key
